<Window x:Class="NovaVpn.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:NovaVpn.App.Models"
        Title="NovaVPN" Height="620" Width="960"
        MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Profile list -->
        <Grid Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,20,20,8">
                <TextBlock Text="NovaVPN" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Profiles" Opacity="0.7" Margin="0,4,0,0" />
            </StackPanel>

            <ListBox Grid.Row="1" Margin="12,0"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                     HorizontalContentAlignment="Stretch"
                     BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ProfileSummary}">
                        <Grid Margin="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Location}" Opacity="0.6" FontSize="12" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="★"
                                       Foreground="#F5C518" VerticalAlignment="Center"
                                       Visibility="{Binding Favorite, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="Refresh" Margin="20,8,20,20"
                    HorizontalAlignment="Stretch" Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Dashboard -->
        <Grid Grid.Column="1" Margin="32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- State badge -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,24">
                <Border Width="120" Height="120" CornerRadius="60"
                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="⛊" FontSize="52" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ConnectionState}" FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,16,0,0" />
                <TextBlock Text="{Binding StatusText}" Opacity="0.7"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Traffic tiles -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,8">
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Download" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding DownRate}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Upload" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding UpRate}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Received" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Received}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Sent" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Sent}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Connect / disconnect -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,16,0,0">
                <Button Content="Connect" Width="160" Height="44" FontSize="16"
                        Command="{Binding ConnectCommand}"
                        Style="{DynamicResource AccentButtonStyle}" />
                <Button Content="Disconnect" Width="160" Height="44" FontSize="16"
                        Margin="16,0,0,0" Command="{Binding DisconnectCommand}" />
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="20,0,0,8" Opacity="0.55" FontSize="12"
                   Text="{Binding ServiceStatus}" />
    </Grid>
</Window>
