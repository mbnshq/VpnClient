<Window x:Class="NovaVpn.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaVpn.App.ViewModels"
        xmlns:views="clr-namespace:NovaVpn.App.Views"
        Title="NovaVPN" Height="640" Width="1000"
        MinHeight="540" MinWidth="820"
        Icon="Assets/NovaVPN.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Map each page view model to its view. -->
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SplitTunnelViewModel}">
            <views:SplitTunnelView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation rail -->
        <Grid Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="NovaVPN" FontSize="20" FontWeight="SemiBold"
                       Margin="20,20,0,16" />

            <ListBox Grid.Row="1" ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding CurrentPage, Mode=TwoWay}"
                     BorderThickness="0" Background="Transparent" Margin="8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:PageViewModel}">
                        <TextBlock Text="{Binding Title}" Padding="8,10" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Text="{Binding Dashboard.ServiceStatus}"
                       TextWrapping="Wrap" Opacity="0.5" FontSize="11" Margin="16,0,16,12" />
        </Grid>

        <!-- Page content -->
        <ContentControl Grid.Column="1" Margin="28,24"
                        Content="{Binding CurrentPage.Content}" />
    </Grid>
</Window>
