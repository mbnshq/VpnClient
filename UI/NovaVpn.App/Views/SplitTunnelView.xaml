<UserControl x:Class="NovaVpn.App.Views.SplitTunnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NovaVpn.App.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Split tunnel" FontSize="20" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Margin="0,12">
            <!-- Be honest: the selection below is stored and shown, but nothing
                 enforces it yet. Per-application routing needs a kernel filtering
                 driver that is not part of this build, so every app currently
                 uses the tunnel regardless of what is ticked. -->
            <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Not enforced yet" FontWeight="SemiBold" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" Margin="0,4,0,0"
                               Text="Per-app routing requires a kernel network-filtering driver that this build does not include. Your choices are saved, but for now every application uses the VPN while it is connected." />
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Enable split tunnelling" IsChecked="{Binding Enabled}" />
                <RadioButton Content="Only checked apps use the VPN" IsChecked="{Binding IncludeMode}"
                             Margin="24,0,0,0" GroupName="mode" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                CornerRadius="8" Padding="4">
            <ListView ItemsSource="{Binding Apps}" BorderThickness="0" Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:AppEntry}">
                        <Grid Margin="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Tunnel}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" DockPanel.Dock="Right" />
            <TextBlock Text="{Binding Status}" Opacity="0.6" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</UserControl>
