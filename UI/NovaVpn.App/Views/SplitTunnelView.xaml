<UserControl x:Class="NovaVpn.App.Views.SplitTunnelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NovaVpn.App.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Split tunnel" FontSize="20" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12">
            <CheckBox Content="Enable split tunnelling" IsChecked="{Binding Enabled}" />
            <RadioButton Content="Only checked apps use the VPN" IsChecked="{Binding IncludeMode}"
                         Margin="24,0,0,0" GroupName="mode" />
        </StackPanel>

        <Border Grid.Row="2" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                CornerRadius="8" Padding="4">
            <ListView ItemsSource="{Binding Apps}" BorderThickness="0" Background="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:AppEntry}">
                        <Grid Margin="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Tunnel}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Path}" Opacity="0.55" FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" DockPanel.Dock="Right" />
            <TextBlock Text="{Binding Status}" Opacity="0.6" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</UserControl>
