<Window x:Class="NovaVpn.App.Views.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter credentials" SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="24">
        <TextBlock x:Name="Prompt" Text="Enter the username and password for this profile."
                   TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,16" />

        <TextBlock Text="Username" Opacity="0.7" Margin="0,0,0,4" />
        <TextBox x:Name="UsernameBox" Padding="6,4" />

        <TextBlock Text="Password" Opacity="0.7" Margin="0,12,0,4" />
        <PasswordBox x:Name="PasswordBox" Padding="6,4" />

        <CheckBox x:Name="SaveBox" Content="Save password" IsChecked="True" Margin="0,16,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="90" IsCancel="True" />
            <Button x:Name="OkButton" Content="Save" Width="90" Margin="12,0,0,0"
                    IsDefault="True" Click="OnOk"
                    Style="{DynamicResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>
</Window>
