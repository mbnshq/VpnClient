<UserControl x:Class="NovaVpn.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <TextBlock Text="Appearance" FontWeight="SemiBold" Opacity="0.8" Margin="0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Theme" VerticalAlignment="Center" Width="140" />
            <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme, Mode=TwoWay}"
                      Width="200" />
        </StackPanel>

        <TextBlock Text="Startup" FontWeight="SemiBold" Opacity="0.8" Margin="0,8" />
        <CheckBox Content="Start minimised to the tray" IsChecked="{Binding StartMinimized}"
                  Margin="0,4" />

        <TextBlock Text="Notifications" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,8" />
        <CheckBox Content="Show notifications" IsChecked="{Binding NotificationsEnabled}"
                  Margin="0,4" />

        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
            <Button Content="Save" Width="120" Command="{Binding SaveCommand}"
                    Style="{DynamicResource AccentButtonStyle}" />
            <TextBlock Text="{Binding Status}" Opacity="0.7" VerticalAlignment="Center"
                       Margin="16,0,0,0" />
        </StackPanel>
    </StackPanel>
</UserControl>
