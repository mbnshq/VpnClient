<UserControl x:Class="NovaVpn.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="About NovaVPN" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="56" Height="56" CornerRadius="12"
                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                <TextBlock Text="⛊" FontSize="30" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="NovaVPN" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Opacity="0.7">
                    <Run Text="Version " /><Run Text="{Binding Version, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding ServiceInfo}" Opacity="0.75" Margin="0,0,0,16"
                   TextWrapping="Wrap" />

        <TextBlock TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8">
            A modern Windows VPN client supporting OpenVPN profiles, per-application
            split tunnelling, multiple simultaneous tunnels and a firewall-backed
            kill switch. The client runs unprivileged and drives the NovaVPN service
            over a secure local channel.
        </TextBlock>

        <TextBlock Text="Help" FontWeight="SemiBold" Margin="0,16,0,4" />
        <TextBlock TextWrapping="Wrap" Opacity="0.7">
            To add a server, use "Add" on the Dashboard and choose your .ovpn file.
            To route only some apps through the VPN, use the Split tunnel page.
            The Logs page shows the service's recent activity.
        </TextBlock>

        <TextBlock Margin="0,16,0,0">
            <Hyperlink NavigateUri="{Binding ProjectUrl}" RequestNavigate="OnNavigate">
                <Run Text="{Binding ProjectUrl, Mode=OneWay}" />
            </Hyperlink>
        </TextBlock>
    </StackPanel>
</UserControl>
