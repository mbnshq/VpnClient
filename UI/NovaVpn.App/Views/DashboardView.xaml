<UserControl x:Class="NovaVpn.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:NovaVpn.App.Models">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Profile list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="8,0,0,8">
                <Button DockPanel.Dock="Right" Content="+ Add" Padding="12,4"
                        Command="{Binding ImportCommand}"
                        ToolTip="Import an OpenVPN (.ovpn) profile" />
                <Button DockPanel.Dock="Right" Content="Edit" Padding="12,4" Margin="0,0,8,0"
                        Command="{Binding EditProfileCommand}"
                        ToolTip="Rename, set username/password, or delete the selected profile" />
                <TextBlock Text="Profiles" Opacity="0.7" VerticalAlignment="Center" />
            </DockPanel>

            <Grid Grid.Row="1">
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                         HorizontalContentAlignment="Stretch" BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="OnProfileDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ProfileSummary}">
                            <Grid Margin="4,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Server}" Opacity="0.6" FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Content="⚙" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Padding="6,0" Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.EditProfileCommand,
                                                  RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Edit this profile" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Empty-state prompt, like a fresh OpenVPN Connect. -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasNoProfiles, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="No profiles yet" Opacity="0.6" HorizontalAlignment="Center" />
                    <Button Content="Import a .ovpn file" Margin="0,12,0,0"
                            Command="{Binding ImportCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>

            <Button Grid.Row="2" Content="Refresh" Margin="0,8,0,0"
                    HorizontalAlignment="Stretch" Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Connection panel -->
        <Grid Grid.Column="1" Margin="32,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,24">
                <Border Width="112" Height="112" CornerRadius="56"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                    <TextBlock Text="⛊" FontSize="48" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ConnectionState}" FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,16,0,0" />
                <TextBlock Text="{Binding StatusText}" Opacity="0.7"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                <Button Content="Set username / password" Margin="0,10,0,0"
                        HorizontalAlignment="Center" Padding="12,4"
                        Command="{Binding EditCredentialsCommand}"
                        Visibility="{Binding SelectedNeedsCredentials, Converter={StaticResource BoolToVisibility}}"
                        ToolTip="This profile signs in with a username and password" />
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="4">
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Download" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding DownRate}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Upload" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding UpRate}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Received" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Received}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Tile}">
                    <StackPanel>
                        <TextBlock Text="Sent" Opacity="0.6" FontSize="12" />
                        <TextBlock Text="{Binding Sent}" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Shown only when the background service is not reachable: one
                 click starts it (a single Windows permission prompt). -->
            <Border Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    CornerRadius="8" Padding="24,20" MaxWidth="420"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="{Binding IsServiceDisconnected, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Background service not running" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ServiceStatus}" Opacity="0.7" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,6,0,0" />
                    <Button Content="Start service" Margin="0,16,0,0" Padding="16,6"
                            HorizontalAlignment="Center"
                            Command="{Binding StartServiceCommand}"
                            Style="{DynamicResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Connect" Width="150" Height="42" FontSize="15"
                        Command="{Binding ConnectCommand}"
                        Style="{DynamicResource AccentButtonStyle}" />
                <Button Content="Disconnect" Width="150" Height="42" FontSize="15"
                        Margin="16,0,0,0" Command="{Binding DisconnectCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
