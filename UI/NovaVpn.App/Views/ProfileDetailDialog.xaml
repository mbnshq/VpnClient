<Window x:Class="NovaVpn.App.Views.ProfileDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="24">
        <TextBlock Text="Profile Name" Opacity="0.7" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Padding="6,4" />

        <TextBlock Text="Server" Opacity="0.7" Margin="0,14,0,4" />
        <TextBox x:Name="ServerBox" Padding="6,4" IsReadOnly="True"
                 Background="Transparent" Opacity="0.85" />
        <TextBlock x:Name="RemotesNote" Opacity="0.5" FontSize="12" Margin="0,4,0,0" />

        <Separator Margin="0,16" />

        <TextBlock Text="Username" Opacity="0.7" Margin="0,0,0,4" />
        <TextBox x:Name="UsernameBox" Padding="6,4" />

        <TextBlock Text="Password" Opacity="0.7" Margin="0,12,0,4" />
        <PasswordBox x:Name="PasswordBox" Padding="6,4" />
        <TextBlock x:Name="PasswordNote" Opacity="0.5" FontSize="12" Margin="0,4,0,0"
                   TextWrapping="Wrap" />

        <CheckBox x:Name="SaveBox" Content="Save password" IsChecked="True" Margin="0,12,0,0" />

        <TextBlock x:Name="AuthNote" Opacity="0.5" FontSize="12" Margin="0,12,0,0"
                   TextWrapping="Wrap" />

        <Separator Margin="0,16" />

        <TextBlock Text="Profile ID" Opacity="0.7" Margin="0,0,0,4" />
        <TextBox x:Name="IdBox" Padding="6,4" IsReadOnly="True"
                 Background="Transparent" Opacity="0.7" FontSize="12" />

        <Grid Margin="0,24,0,0">
            <Button Content="Delete profile" HorizontalAlignment="Left" Padding="14,6"
                    Click="OnDelete" Foreground="#E53935" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" IsCancel="True" />
                <Button Content="Save changes" Width="120" Margin="12,0,0,0"
                        IsDefault="True" Click="OnSave"
                        Style="{DynamicResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>
