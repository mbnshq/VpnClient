<UserControl x:Class="NovaVpn.App.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Statistics" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <Border Style="{StaticResource Tile}" Margin="0,0,0,8" HorizontalAlignment="Left"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="Status" Opacity="0.6" FontSize="12" />
                <TextBlock Text="{Binding State}" FontSize="20" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <UniformGrid Columns="2" HorizontalAlignment="Left">
            <Border Style="{StaticResource Tile}" Padding="20,14" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="Download rate" Opacity="0.6" FontSize="12" />
                    <TextBlock Text="{Binding DownRate}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}" Padding="20,14" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="Upload rate" Opacity="0.6" FontSize="12" />
                    <TextBlock Text="{Binding UpRate}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}" Padding="20,14" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="Total received" Opacity="0.6" FontSize="12" />
                    <TextBlock Text="{Binding Received}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}" Padding="20,14" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="Total sent" Opacity="0.6" FontSize="12" />
                    <TextBlock Text="{Binding Sent}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}" Padding="20,14" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="Peak download" Opacity="0.6" FontSize="12" />
                    <TextBlock Text="{Binding PeakDownText}" FontSize="18" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
